# Node.js uchun asosiy ignore
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Build natijalari (serverda Docker o'zi build qiladi, shuning uchun git'ga kerak emas)
dist/
/build/
.next/
.nuxt/
out/

# Electron (desktop) — o'zining alohida bog'liqliklari/build natijalari
# (electron/build/icon.png esa KERAK — electron-builder'ning manba resurs
# papkasi, shu bois yuqoridagi /build/ ATAYLAB faqat ILDIZ darajasiga
# cheklangan, electron/build/ga tegmaydi).
electron/dist/
electron/dist-electron/

# Muhit o'zgaruvchilari (Eng muhim xavfsizlik qoidasi!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# MUHIM: .env.capacitor ATAYLAB bu ro'yxatda EMAS (.env.electron kabi) -
# tarkibi (VITE_API_URL, VITE_GOOGLE_CLIENT_ID) MAXFIY EMAS (OAuth client
# ID va ochiq API manzili). Bu fayl ILGARI shu yerda gitignore qilingan
# edi - shu sabab GitHub Actions'da checkout qilinganda UMUMAN mavjud
# bo'lmagan, VITE_API_URL bo'sh qolib, ilova nisbiy "/api/v1"ga (demak
# WebView'ning o'z ICHKI "https://localhost" manziliga - hech qanday
# haqiqiy serverga EMAS) tushib qolgan edi - bu CI'da qurilgan HAR BIR
# APK'da login/ro'yxatdan o'tish/barcha backend so'rovlari butunlay
# ishlamasligining haqiqiy sababi bo'lgan.

# IDE va OS fayllari
.vscode/
.idea/
.DS_Store
Thumbs.db

# Loglar va temp fayllar
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# TypeScript incremental build keshi — HAR bir `tsc` chaqiruvida (build,
# build:capacitor, build:desktop) o'zgaradi. Avval GIT'DA KUZATILGAN edi —
# bu esa CI'dagi build-apk/build-desktop job'larining "commit va push"
# bosqichida `git rebase origin/main`ni "You have unstaged changes"
# xatosi bilan BUZAR edi (build bosqichlari shu faylni allaqachon
# o'zgartirib qo'ygan bo'lardi, working tree rebase uchun toza bo'lmay
# qolardi).
tsconfig.tsbuildinfo