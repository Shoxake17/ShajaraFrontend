<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM fallback (bizning AjdoFirebaseMessagingService har doim o'zi
             notification quradi, shuning uchun bu meta-data'lar odatda
             ishlatilmaydi — lekin agar biror sabab bilan tizim FCM'ni o'zi
             avtomatik ko'rsatsa (masalan ilova umuman ishga tushmagan holatda),
             shu izchil ikonka/rang/kanal ishlatilishi uchun qoldirilgan). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="chat_messages" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notify" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />

        <!-- @capacitor/push-notifications'ning stock MessagingService'i
             (kutubxona AAR manifestidan meros) olib tashlanadi — o'rniga
             pastdagi AjdoFirebaseMessagingService bitta xizmat sifatida
             ro'yxatga olinadi (large icon/rangli logotip uchun, quyida). -->
        <service
            android:name="com.capacitorjs.plugins.pushnotifications.MessagingService"
            tools:node="remove" />

        <service
            android:name=".AjdoFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Qo'ng'iroq — to'liq native (Kotlin, LiveKit Android SDK) ekranlar,
             WebView emas (qulf ekranida jiringlash + ekran ulashishni
             boshlash uchun shart). -->
        <activity
            android:name=".calls.IncomingCallActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".calls.CallActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|screenLayout|uiMode"
            android:theme="@style/AppTheme.NoActionBar" />
        <service
            android:name=".calls.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
        <!-- Qo'ng'iroq ulanishini CallActivity umridan MUSTAQIL saqlaydi —
             foydalanuvchi ilovadan chiqib ketsa (Uy tugmasi, Recents'dan
             surib tashlasa, boshqa sahifaga o'tsa) qo'ng'iroq FAQAT
             foydalanuvchi Qizil tugmani bosgandagina tugaydi, Activity
             yo'q qilinganda EMAS — bu doimiy bildirishnoma (foreground
             xizmat) orqali OS'ga "faol qo'ng'iroq bor" deb bildiriladi,
             aks holda jarayon fon rejimida tez orada o'ldiriladi. -->
        <service
            android:name=".calls.CallService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera"
            android:stopWithTask="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ (API 33+) — push bildirishnoma ko'rsatish uchun ishga
         tushirilishi kerak bo'lgan runtime ruxsat (@capacitor/push-notifications
         PushNotifications.requestPermissions() shu bilan ishlaydi). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Qo'ng'iroq (ovoz/video/ekran ulashish) uchun -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- IncomingCallActivity.startRinging() Vibrator.vibrate()ni HAR BIR
         kiruvchi qo'ng'iroqda so'zsiz chaqiradi — bu ruxsat manifestda
         E'LON QILINMAGAN bo'lsa, chaqiruv SecurityException tashlaydi
         (hech qanday try/catch tomonidan tutilmagan, asosiy threadda) va
         BUTUN ilovani krash qiladi. Aynan shu — qabul qiluvchi tomonda,
         HAR SAFAR, audio HAM video qo'ng'iroqda ham takrorlangan krashning
         eng ehtimolli sababi edi. -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <!-- Kiruvchi qo'ng'iroqni qulf ekranida ham to'liq ekran ko'rsatish
         uchun — Android 14+ (API 34) foydalanuvchidan ANIQ ruxsat talab
         qiladi (Sozlamalar), ilova ichida shunga yo'naltirish kerak
         bo'ladi. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Ekran ulashish (MediaProjection) foreground xizmati uchun -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- CallService — qo'ng'iroqni Activity umridan mustaqil, fonda ham
         tirik saqlash uchun (Android 14+ shu turlarni ANIQ e'lon qilishni
         talab qiladi). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
</manifest>
